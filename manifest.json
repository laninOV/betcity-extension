{
  "manifest_version": 3,
  "name": "Tennis Prediction Analysis",
  "version": "1.0",
  "description": "Анализ теннисных матчей с продвинутыми алгоритмами",
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "content_scripts": [
    {
      "matches": ["*://*.betcity.ru/*"],
      "js": ["content.js"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Tennis Analysis"
  }
}
